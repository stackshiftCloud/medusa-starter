NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medusa
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-long-random-value
COOKIE_SECRET=replace-with-a-different-long-random-value
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000,http://localhost:9000

# StackShift injects these in hosted environments.
STACKSHIFT_ENVIRONMENT_ID=
STACKSHIFT_RELEASE_REVISION=
STACKSHIFT_TELEMETRY_TOKEN=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_FILE_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
STACKSHIFT_MAIL_API_KEY=
STACKSHIFT_MAIL_URL=https://api.stackshift.cloud/v1
STACKSHIFT_MAIL_FROM=
STACKSHIFT_MAIL_SANDBOX=false
STACKSHIFT_MAIL_SANDBOX_TO=

# Merchant-owned integration credentials; use test keys outside production.
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CALLBACK_URL=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_REDIRECT_URL=
