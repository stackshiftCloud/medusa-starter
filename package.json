{
  "name": "@stackshift-cloud/medusa-starter",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "start": "turbo start",
    "lint": "turbo lint",
    "test": "turbo test",
    "backend:seed": "turbo seed --filter=@dtc/backend",
    "backend:dev": "turbo dev --filter=@dtc/backend",
    "storefront:dev": "turbo dev --filter=@dtc/storefront"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5",
      "fast-xml-parser": "5.10.0",
      "immutable": "3.8.3",
      "protobufjs": "7.6.3",
      "esbuild": "0.25.12",
      "axios": "1.16.0",
      "multer": "2.2.0",
      "vite": "6.4.3",
      "tar": "7.5.3",
      "minimatch@9.0.5": "9.0.6",
      "lodash": "4.18.0",
      "picomatch@4.0.3": "4.0.4",
      "picomatch@2.3.1": "2.3.2",
      "path-to-regexp@8.3.0": "8.4.0",
      "path-to-regexp@0.1.12": "0.1.13",
      "sigstore@2.3.1": "4.1.1",
      "rollup@4.53.3": "4.59.0",
      "form-data@4.0.5": "4.0.6",
      "cross-spawn@7.0.3": "7.0.5",
      "glob@10.4.2": "10.5.0"
    }
  },
  "devDependencies": {
    "@medusajs/eslint-plugin": "2.16.0",
    "eslint": "^9.39.4",
    "jiti": "^2.7.0",
    "prettier": "^3.2.5",
    "turbo": "2.9.14"
  },
  "version": "2026.7.4",
  "description": "StackShift's maintained Medusa v2 DTC starter."
}
