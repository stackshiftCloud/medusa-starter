{
  "name": "@stackshift-cloud/medusa-file",
  "version": "0.1.0",
  "description": "StackShift object storage provider for the Medusa v2 File Module.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js",
      "require": "./dist/provider.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.js"
    },
    "./s3-client": {
      "types": "./dist/s3-client.d.ts",
      "import": "./dist/s3-client.js",
      "require": "./dist/s3-client.js"
    },
    "./sigv4": {
      "types": "./dist/sigv4.d.ts",
      "import": "./dist/sigv4.js",
      "require": "./dist/sigv4.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "peerDependencies": {
    "@medusajs/framework": ">=2.11.0 <3"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
